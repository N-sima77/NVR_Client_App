    '****************************************************************
    '* Function Name        : b_LiveStart_Click
    '* Overview             : Start live video play
    '****************************************************************
    Private Sub b_LiveStart_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles b_LiveStart.Click
        'Define variables
        Dim lRet As Long
        Dim lChannel As Long
        Dim lBlockmode As Long

        '----------------------------------------
        'Control 1
        '----------------------------------------
        'Connect to the device
        lRet = AxipropsapiCtrl1.Open
        Logging("[Function 1] Open:" & CStr(lRet))

        If lRet > -1 Then
            'Start Live
            lChannel = 1
            lBlockmode = 0
            lRet = AxipropsapiCtrl1.PlayLive(lChannel, lBlockmode)
            Logging("[Function 1] PlayLive(Start):" & CStr(lRet))

            If lRet <> 0 Then
            	AxipropsapiCtrl1.Close()
	            Logging("[Function 1] Close")
            Else
		        '----------------------------------------
		        'Control 2
		        '----------------------------------------
	            'Connect to the device
	            lRet = AxipropsapiCtrl2.Connect(AxipropsapiCtrl1.UID)
	            Logging("[Function 2] Connect:" & CStr(lRet))

	            'Start Live
	            If lRet > -1 Then
		            lChannel = 2
		            lBlockmode = 0
	                lRet = AxipropsapiCtrl2.PlayLive(lChannel, lBlockmode)
	                Logging("[Function 2] PlayLive(Start):" & CStr(lRet))

		            If lRet <> 0 Then
		            	AxipropsapiCtrl2.Disconnect()
	                    Logging("[Function 2] Disconnect")
		            End If
	            End If

                'Status:Live
                gPlayStatus = 1
	        End If
        End If
    End Sub
    
    '****************************************************************
    '* Function Name        : b_liveStop
    '* Overview             : Stop live video play
    '****************************************************************
    Private Sub b_liveStop_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles b_liveStop.Click
        'Define variables
        Dim lRet As Long
        Dim lCommand As Long
        Dim lSpeed As Long
        Dim lBlockmode As Long

        'Check the play status
        If (gPlayStatus = 1) Then
	        'StopLive
	        lCommand = 1
	        lSpeed = 1
	        lBlockmode = 0
	        lRet = AxipropsapiCtrl1.PlayControl(lCommand, lSpeed, lBlockmode)
	        Logging("[Function 1] PlayLive(Stop):" & CStr(lRet))

	        'StopLive
	        lCommand = 1
	        lSpeed = 0
	        lBlockmode = 0
	        lRet = AxipropsapiCtrl2.PlayControl(lCommand, lSpeed, lBlockmode)
	        Logging("[Function2] PlayLive(Stop):" & CStr(lRet))

	        'Close connection to the device
	        AxipropsapiCtrl2.Disconnect()
	        Logging("[Function 2] Disconnect")
	        AxipropsapiCtrl1.Close()
	        Logging("[Function 1] Close")

	        'ClearImage
	        AxipropsapiCtrl1.ClearImage()
	        Logging("[Function 1] ClearImage")
	        AxipropsapiCtrl2.ClearImage()
	        Logging("[Function 2] ClearImage")

	        'Change status
            gPlayStatus = 0
		Else
	        Logging("[Message] No live.")
	    End If
    End Sub


